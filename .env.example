# Database — matches docker-compose.yml defaults
DATABASE_URL="postgresql://intern_user:intern_password@localhost:5432/intern_community"

# NextAuth
AUTH_SECRET="change-me-in-production-use-openssl-rand-base64-32"

# GitHub OAuth App — create at https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Gemini API (support chat)
# Generate key at: https://aistudio.google.com/
GEMINI_API_KEY="your api key"
GEMINI_MODEL="gemini-2.5-flash" # khuyến nghị là gemini-2.5-flash
