generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://khanh_dev:password123@localhost:5432/intern_hub"
}

model Category {
  id      String   @id @default(cuid())
  name    String
  slug    String   @unique
  modules Module[]
}

model Module {
  id          String   @id @default(cuid())
  name        String
  description String
  slug        String   @unique
  voteCount   Int      @default(0)
  createdAt   DateTime @default(now())
  authorName  String   @default("Khánh Dev")
  repoUrl     String?
  demoUrl     String?
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id])
}